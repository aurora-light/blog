{
	"name": "lucky-snail-blog",
	"description": "基于 Next.js + tailwindcss + framer motion + contentlayer + github actions + github issues 的个人博客",
	"keywords": [
		"dino",
		"nextjs",
		"tailwindcss",
		"framer motion",
		"contentlayer",
		"github actions",
		"github issues",
		"blog"
	],
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"prepare": "husky install",
		"pre-commit": "lint-staged",
		"dev": "next dev ",
		"build": "next build",
		"start": "next start -p 3003",
		"start:static": "serve -s out -l 3003",
		"lint": "eslint --ext .ts,.js,.jsx,.tsx --fix . ",
		"lint-staged": "lint-staged",
		"sync-post": "node ./scripts/sync-post.js",
		"generate-rss": "node ./scripts/generate-rss.js",
		"serve": "serve -s out"
	},
	"dependencies": {
		"@emotion/is-prop-valid": "^1.4.0",
		"@radix-ui/react-aspect-ratio": "^1.1.8",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-hover-card": "^1.1.15",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/react-navigation-menu": "^1.2.14",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-toast": "^1.2.15",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@splinetool/react-spline": "^4.1.0",
		"class-variance-authority": "^0.7.1",
		"client-only": "^0.0.1",
		"clsx": "^2.1.1",
		"contentlayer": "^0.3.4",
		"dayjs": "^1.11.20",
		"dotenv": "^16.6.1",
		"framer-motion": "^11.18.2",
		"fs-extra": "^11.3.4",
		"github-api": "^3.4.0",
		"gray-matter": "^4.0.3",
		"lucide-react": "^0.408.0",
		"next": "14.2.4",
		"next-contentlayer": "^0.3.4",
		"next-themes": "^0.3.0",
		"next-view-transitions": "^0.3.5",
		"node-cron": "^3.0.3",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-medium-image-zoom": "^5.4.3",
		"react-pdf": "^10.4.1",
		"react-wrap-balancer": "^1.1.1",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-prism-plus": "^2.0.2",
		"rehype-slug": "^6.0.0",
		"remark-gfm": "3.0.1",
		"rss": "^1.2.2",
		"server-only": "^0.0.1",
		"sharp": "^0.33.5",
		"sonner": "^1.7.4",
		"tailwind-merge": "^2.6.1",
		"tailwindcss-animate": "^1.0.7",
		"tocbot": "^4.36.4",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@types/node": "^20.19.39",
		"@types/react": "18.2.65",
		"@types/react-dom": "^18.3.7",
		"@types/rss": "^0.0.32",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"eslint": "^8.57.1",
		"eslint-config-next": "14.2.4",
		"eslint-config-prettier": "^9.1.2",
		"eslint-plugin-prettier": "^5.5.5",
		"globby": "^14.1.0",
		"husky": "^8.0.3",
		"lint-staged": "^15.5.2",
		"postcss": "^8.5.10",
		"prettier": "^3.8.3",
		"remark-rehype": "^11.1.2",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.9.3",
		"unified": "^11.0.5"
	},
	"overrides": {
		"next-contentlayer": {
			"next": "$next"
		}
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint --fix",
			"prettier --write"
		]
	}
}
